# MySQL / WAMP
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rentacar_crm

# JWT
JWT_SECRET=cambia-este-secreto

# Secreto compartido que n8n debe enviar en el header x-ingest-secret
# al llamar los endpoints /api/webhooks/*. Debe coincidir con el valor
# configurado en los nodos HTTP Request del workflow de n8n.
INGEST_SECRET=cambia-este-secreto

# Usuario inicial del dashboard (usado solo por scripts/seed-admin.js)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# API key de Anthropic — la usa el workflow de n8n y la sincronización
# directa de Gmail para clasificar correos, extraer datos de la cotización
# y redactar las respuestas.
ANTHROPIC_API_KEY=

# URL pública de este dashboard (sin slash final)
APP_URL=http://localhost:3000

# Credenciales de Google Cloud OAuth2 (Gmail API) para el botón
# "Conectar Gmail" del dashboard. Redirect URI: {APP_URL}/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
